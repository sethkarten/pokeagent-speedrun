{
  "name": "Codex CLI Agent Container",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "runArgs": ["--cap-add=NET_ADMIN", "--security-opt=seccomp=unconfined", "--network=bridge", "--add-host=host.docker.internal:host-gateway"],
  "mounts": [
    "source=${localWorkspaceFolder}/.pokeagent_cache/${localEnv:RUN_DATA_ID}/codex_memory,target=/home/codex-agent/.codex,type=bind",
    "source=${localWorkspaceFolder}/.pokeagent_cache/${localEnv:RUN_DATA_ID}/agent_scratch_space,target=/workspace,type=bind"
  ],
  "containerEnv": {
    "MCP_PORT": "${localEnv:MCP_PORT}",
    "GAME_SERVER_PORT": "${localEnv:GAME_SERVER_PORT}",
    "POKEMON_MCP_SERVER_URL": "http://host.docker.internal:${localEnv:MCP_PORT}",
    "RUN_DATA_ID": "${localEnv:RUN_DATA_ID}",
    "OPENROUTER_API_KEY": "${localEnv:OPENROUTER_API_KEY}"
  },
  "remoteUser": "codex-agent",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "postCreateCommand": "echo '✅ Codex CLI agent container ready'",
  "features": {}
}
